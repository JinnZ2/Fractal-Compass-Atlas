          { "remote": "shapes/icosahedron.json", "as": "atlas/remote/rosetta/shapes/icosahedron.json" },
          { "remote": "data/essence-traits.json", "as": "atlas/remote/rosetta/essence-traits.json" },
          { "remote": "data/seed-catalog.json", "as": "atlas/remote/rosetta/seed-catalog.json" }
