    "local_manifests": [
      "fractals/**/*.json",
      "atlas/**/*.json",
      "glyphs/**/*.json",
      "guides/**/*.md"
    ],

    "merge": {
      "order": ["local", "compass_core", "rosetta", "polyhedral", "emotions", "defense", "audit", "biogrid"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",
    "integrity": { "enabled": true, "hash": "sha256", "allow_missing": false },
    "consent": { "license": "CC-BY-4.0", "share_ok": true, "redact_rules": ["**/private/**", "*.secrets.json"] }
  }
