        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "polyhedral",
        "repo": "https://github.com/JinnZ2/Polyhedral-Intelligence",
        "ref": "main",
        "paths": ["glyphs/**/*.json", "atlas/shapes.json", "scrolls/*.md"],
        "mounts": [
          { "remote": "atlas/shapes.json", "as": "atlas/remote/polyhedral/shapes.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "emotions",
        "repo": "https://github.com/JinnZ2/Emotions-as-Sensors",
        "ref": "main",
        "paths": ["sensors/**/*.json", "glyphs/**/*.json", "atlas/**/*.json"],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "defense",
        "repo": "https://github.com/JinnZ2/Symbolic-Defense-Protocol",
        "ref": "main",
        "paths": ["defenses/**/*.json", "protocols/**/*.json"],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "audit",
        "repo": "https://github.com/JinnZ2/ai-human-audit-protocol",
        "ref": "main",
        "paths": ["glyphs/**/*.json", "protocols/**/*.md", "logs/**/*.json"],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "compass_core",
        "repo": "https://github.com/JinnZ2/Fractal_Compass_Core",
        "ref": "main",
        "paths": ["glyphs/**/*.json", "bloom/**/*.json", "engine/**/*.py"],
        "mounts": [
          { "remote": "glyphs/glyph_set.json", "as": "atlas/remote/compass_core/glyph_set.json" },
          { "remote": "bloom/bloom_logic.json", "as": "atlas/remote/compass_core/bloom_logic.json" }
        ],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "biogrid",
        "repo": "https://github.com/JinnZ2/BioGrid2.0",
        "ref": "main",
        "paths": ["planned/glyphs/atlas.json", "registry/atlas.glyphs.json"],
        "mounts": [
          { "remote": "planned/glyphs/atlas.json", "as": "atlas/remote/biogrid/planned.json" },
          { "remote": "registry/atlas.glyphs.json", "as": "atlas/remote/biogrid/registry.json" }
